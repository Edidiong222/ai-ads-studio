# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=aiads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS (comma-separated origins when DEBUG=false)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
# Classroom / Vercel: allow any origin (Bearer auth; use only if you accept the risk)
# CORS_ALLOW_ALL=true

# Vercel / Neon (production — do not use USE_SQLITE on Vercel)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# SERVE_FRONTEND=false

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Groq LLM (required for generate endpoints)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase storage (optional — falls back to local /media/)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_STORAGE_BUCKET=pdfs

# Production (Vercel) — see docs/VERCEL_ENV_VARS.md
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require
# SERVE_FRONTEND=false
# CORS_ALLOW_ALL=true
